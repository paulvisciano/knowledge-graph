# ═══════════════════════════════════════════════════════════════════════════════
# Knowledge Graph — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and customize.
# llama-servers run on the host (macOS Metal). LightRAG runs in Docker.
# ═══════════════════════════════════════════════════════════════════════════════

COMPOSE_PROJECT_NAME=knowledge-graph

# ─── General ────────────────────────────────────────────────────────────────
MODEL_DIR=${HOME}/models

# ─── llama-server ports (host) ──────────────────────────────────────────────
LLM_PORT=8080
EMBED_MODEL_PORT=8081
RERANKER_PORT=8082

# ─── LightRAG (Docker) ──────────────────────────────────────────────────────
LIGHTRAG_PORT=9621

# ─── LLM — Gemma 4 12B OBLITERATED on host llama-server ────────────────────
LLM_BINDING=openai
LLM_MODEL=Gemma-4-12B-OBLITERATED-Q4_K_M
LLM_BINDING_HOST=http://host.docker.internal:8080
LLM_BINDING_API_KEY=llama-server

QUERY_LLM_MODEL=Gemma-4-12B-OBLITERATED-Q4_K_M
QUERY_LLM_BINDING=openai
QUERY_LLM_BINDING_HOST=http://host.docker.internal:8080
QUERY_LLM_BINDING_API_KEY=llama-server

EXTRACT_OPENAI_LLM_TEMPERATURE=0.1
EXTRACT_OPENAI_LLM_MAX_TOKENS=2048
QUERY_OPENAI_LLM_TEMPERATURE=0.7
QUERY_OPENAI_LLM_MAX_TOKENS=1024

# ─── Embedding — nomic-embed-text-v2-moe on host llama-server ───────────────
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=nomic-embed-text-v2-moe.Q6_K
EMBEDDING_DIM=768
EMBEDDING_BINDING_HOST=http://host.docker.internal:8081
EMBEDDING_BINDING_API_KEY=llama-server

# ─── Reranker — bge-reranker-v2-m3 on host llama-server ────────────────────
RERANK_BINDING=jina
RERANK_MODEL=bge-reranker-v2-m3-Q4_K_M
RERANK_BINDING_HOST=http://host.docker.internal:8082/v1/rerank
RERANK_BINDING_API_KEY=llama-server
RERANK_BY_DEFAULT=true
MIN_RERANK_SCORE=-1

# ─── VLM — same model as LLM ──────────────────────────────────────────────
VLM_PROCESS_ENABLE=true
VLM_LLM_BINDING=openai
VLM_LLM_MODEL=Gemma-4-12B-OBLITERATED-Q4_K_M
VLM_LLM_BINDING_HOST=http://host.docker.internal:8080
VLM_LLM_BINDING_API_KEY=llama-server

# ─── Storage (file-based defaults) ──────────────────────────────────────────
WORKING_DIR=/app/data/rag_storage
INPUT_DIR=/app/data/inputs
CHUNK_SIZE=1500
CHUNK_OVERLAP_SIZE=150

# ─── Timeouts ───────────────────────────────────────────────────────────────
LLM_TIMEOUT=900