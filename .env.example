# ═══════════════════════════════════════════════════════════════════════════════
# Knowledge Graph — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Single config file for the entire stack.
# Copy to .env and customize:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

COMPOSE_PROJECT_NAME=knowledge-graph

# ─── General ────────────────────────────────────────────────────────────────
MODEL_DIR=${HOME}/models

# ─── Docker Desktop VM (macOS host) ──────────────────────────────────────────
# Total memory allocated to the Docker Desktop VM. Cannot be set via compose;
# scripts/setup-docker.sh syncs this to Docker Desktop's settings-store.json.
# Container mem_limit caps live in docker-compose.yml and sum to 1.75 GiB.
# Default 1.5 GiB covers those caps plus Docker's own overhead on a 16 GB host.
DOCKER_VM_MEMORY_MIB=1536

# ─── llama-server ports (host) ──────────────────────────────────────────────
LLM_PORT=8080
EMBED_MODEL_PORT=8081
RERANKER_PORT=8082
WHISPER_PORT=8090

# ─── LLM — Gemma 4 12B OBLITERATED on host llama-server ────────────────────
LLM_BINDING=openai
LLM_MODEL=Gemma-4-12B-OBLITERATED-Q4_K_M
LLM_BINDING_HOST=http://host.docker.internal:8080
LLM_BINDING_API_KEY=llama-server

QUERY_LLM_MODEL=Gemma-4-12B-OBLITERATED-Q4_K_M
QUERY_LLM_BINDING=openai
QUERY_LLM_BINDING_HOST=http://host.docker.internal:8080
QUERY_LLM_BINDING_API_KEY=llama-server

EXTRACT_OPENAI_LLM_TEMPERATURE=0.1
EXTRACT_OPENAI_LLM_MAX_TOKENS=2048
QUERY_OPENAI_LLM_TEMPERATURE=0.7
QUERY_OPENAI_LLM_MAX_TOKENS=1024

# ─── Embedding — BGE-M3 on host llama-server ────────────────────────────────
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=bge-m3-Q4_K_M
EMBEDDING_DIM=1024
EMBEDDING_BINDING_HOST=http://host.docker.internal:8081
EMBEDDING_BINDING_API_KEY=llama-server

# ─── Reranker — bge-reranker-v2-m3 on host llama-server ────────────────────
RERANK_BINDING=jina
RERANK_MODEL=bge-reranker-v2-m3-Q4_K_M
RERANK_BINDING_HOST=http://host.docker.internal:8082/v1/rerank
RERANK_BINDING_API_KEY=llama-server
RERANK_BY_DEFAULT=true
MIN_RERANK_SCORE=-1

# ─── VLM — same model as LLM ──────────────────────────────────────────────
VLM_PROCESS_ENABLE=true
VLM_LLM_BINDING=openai
VLM_LLM_MODEL=Gemma-4-12B-OBLITERATED-Q4_K_M
VLM_LLM_BINDING_HOST=http://host.docker.internal:8080
VLM_LLM_BINDING_API_KEY=llama-server
VLM_IMAGE_MAX_DIM=768

# ─── LightRAG Server ────────────────────────────────────────────────────────
LIGHTRAG_PORT=9621
LIGHTRAG_HOST=0.0.0.0
LIGHTRAG_WEBUI_TITLE="Memory Search"
LIGHTRAG_WEBUI_DESCRIPTION="Graph-based RAG for personal knowledge"

# Use JSON mode for entity extraction to avoid delimiter parsing issues
# with LLMs that output |#| instead of <|#|> (e.g., Gemma OBLITERATED).
ENTITY_EXTRACTION_USE_JSON=true

OLLAMA_EMULATING_MODEL_TAG=latest

# ─── Storage ─────────────────────────────────────────────────────────────────
WORKING_DIR=/app/data/rag_storage
INPUT_DIR=/app/data/inputs
CHUNK_SIZE=1500
CHUNK_OVERLAP_SIZE=150

# PostgreSQL storage — KV, Vector, DocStatus in PG; Graph stays NetworkX.
# Switching to PGGraphStorage requires the AGE extension (Dockerfile.postgres).
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=lightrag
POSTGRES_PASSWORD=lightrag
POSTGRES_DATABASE=lightrag
POSTGRES_VECTOR_INDEX_TYPE=HNSW

# ─── Timeouts ────────────────────────────────────────────────────────────────
LLM_TIMEOUT=900

# ─── Knowledge Graph API ──────────────────────────────────────────────────────
API_PORT=8000
LIGHTRAG_URL=http://lightrag:9621

# ─── Nexus UI ────────────────────────────────────────────────────────────────
NEXUS_PORT=3000
LLAMA_HOST=host.docker.internal